# Copy to .env (dev) or set via `nexus vibe env set <appId> KEY=VALUE` (deployed).
# Validation: server/env.mjs — the server refuses to half-boot on an invalid set.
# Rule: server secrets ONLY live here / in the host's secret store. Anything
# imported from src/ ships to every browser — never put a secret there.

PORT=4000
# CONFIG_PATH=starter.config.json   # boot a different product: point at another config

# --- Auth seam (optional; set BOTH to enable the login gate) ---
# AUTH_USERS=maya@example.com:change-me,ops@example.com:change-me-too
# APP_SECRET=a-long-random-string-at-least-16-chars

# --- Accounts mode (self-serve signup + verification/reset/deletion) ---
# AUTH_MODE=accounts            # + APP_SECRET; mail lands in /api/outbox until SMTP is wired
# SMTP_URL=smtp://…             # setting this disables the dev outbox (wire server/email.mjs)

# --- Jobs ---
# DIGEST_EVERY_MS=3600000       # recurring digest job (rollups → app_state)
# DIGEST_TO=ops@example.com     # optional mail target for the digest

# --- Native warehouse (persistent data spine via the Nexus Google Cloud connector) ---
# WAREHOUSE=bigquery               # unset = in-memory mock (same API either way)
# WAREHOUSE_CREDENTIAL_ID=…        # nexus tool credentials <toolId> — the TOOL-SCOPED id
# WAREHOUSE_TOOL_ID=…              # defaults to the Google Cloud marketplace connector
# BQ_DATASET=nx_app
# BQ_LOCATION=EU                   # MUST match the dataset's real region
# BQ_PROJECT=                      # optional explicit project

# --- Feature flags (one flag gates nav + page + API; "0" disables) ---
# FEATURE_TEAMS=0
# FEATURE_WEBHOOKS=0
# FEATURE_THEME=0

# --- Nexus platform (server-side only) ---
# NEXUS_API_KEY=nxs_xxx
# NEXUS_BASE_URL=https://your-nexus-server
