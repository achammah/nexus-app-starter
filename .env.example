# Copy to .env (dev) or set via `nexus vibe env set <appId> KEY=VALUE` (deployed).
# Validation: server/env.mjs — the server refuses to half-boot on an invalid set.

PORT=4000

# --- Auth seam (optional; set BOTH to enable the login gate) ---
# AUTH_USERS=maya@example.com:change-me,ops@example.com:change-me-too
# APP_SECRET=a-long-random-string-at-least-16-chars

# --- Nexus platform (server-side only) ---
# NEXUS_API_KEY=nxs_xxx
# NEXUS_BASE_URL=https://your-nexus-server
