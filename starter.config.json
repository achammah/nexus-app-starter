      "sampleRows": [
        {
          "id": "doc_1",
          "title": "Q3 launch plan",
          "status": "In review",
          "body": [
            {
              "id": "db1a",
              "type": "h1",
              "text": "Q3 launch plan"
            },
            {
              "id": "db1b",
              "type": "p",
              "text": "The quarterly rollout happens in three phases, each gated on the previous one landing cleanly. The goal is a controlled ramp rather than a single big-bang release."
            },
            {
              "id": "db1c",
              "type": "h2",
              "text": "Phase one \u2014 private beta"
            },
            {
              "id": "db1d",
              "type": "p",
              "text": "A small private cohort gets access first. We watch activation and time-to-value closely and fix the sharp edges before widening the door."
            },
            {
              "id": "db1e",
              "type": "h2",
              "text": "Phase two \u2014 waitlist"
            },
            {
              "id": "db1f",
              "type": "p",
              "text": "Once the beta stabilises, the waitlist converts in batches. Support load and infrastructure headroom decide the batch size."
            },
            {
              "id": "db1g",
              "type": "quote",
              "text": "Ship the ramp, not the big bang."
            }
          ],
