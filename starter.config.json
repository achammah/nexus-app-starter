      "sampleRows": [
        {
          "id": "doc_1",
          "title": "Q3 launch plan",
          "status": "In review",
          "body": [
            { "id": "db1a", "type": "h1", "text": "Q3 launch plan" },
            { "id": "db1b", "type": "p", "text": "The quarterly rollout happens in three phases, each gated on the previous one landing cleanly. The goal is a controlled ramp rather than a single big-bang release." },
            { "id": "db1c", "type": "h2", "text": "Phase one — private beta" },
            { "id": "db1d", "type": "p", "text": "A small private cohort gets access first. We watch activation and time-to-value closely and fix the sharp edges before widening the door." },
            { "id": "db1e", "type": "h2", "text": "Phase two — waitlist" },
            { "id": "db1f", "type": "p", "text": "Once the beta stabilises, the waitlist converts in batches. Support load and infrastructure headroom decide the batch size." },
            { "id": "db1g", "type": "quote", "text": "Ship the ramp, not the big bang." }
          ]
        },
        {
          "id": "doc_2",
          "title": "Onboarding playbook",
          "status": "Draft",
          "body": [
            { "id": "db2a", "type": "h1", "text": "Onboarding playbook" },
            { "id": "db2b", "type": "p", "text": "A new customer should reach their first real outcome inside the first session. Everything in this playbook works backward from that moment." },
            { "id": "db2c", "type": "h2", "text": "The first session" },
            { "id": "db2d", "type": "ul", "text": "Connect the primary data source" },
            { "id": "db2e", "type": "ul", "text": "Import a starter dataset so the app is never empty" },
            { "id": "db2f", "type": "ul", "text": "Land one visible win before the call ends" },
            { "id": "db2g", "type": "p", "text": "The empty state is the enemy. Seed it, and the product sells itself." }
          ]
        }
      ],
      "contextFields": [
        "title",
        "status"
      ]
    },
