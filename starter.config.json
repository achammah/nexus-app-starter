        {
          "id": "doc_2",
          "title": "Onboarding playbook",
          "status": "Draft",
          "body": [
            {
              "id": "db2a",
              "type": "h1",
              "text": "Onboarding playbook"
            },
            {
              "id": "db2b",
              "type": "p",
              "text": "A new customer should reach their first real outcome inside the first session. Everything in this playbook works backward from that moment."
            },
            {
              "id": "db2c",
              "type": "h2",
              "text": "The first session"
            },
            {
              "id": "db2d",
              "type": "ul",
              "text": "Connect the primary data source"
            },
            {
              "id": "db2e",
              "type": "ul",
              "text": "Import a starter dataset so the app is never empty"
            },
            {
              "id": "db2f",
              "type": "ul",
              "text": "Land one visible win before the call ends"
            },
            {
              "id": "db2g",
              "type": "p",
              "text": "The empty state is the enemy. Seed it, and the product sells itself."
            }
          ]
        }
