{
  "name": "nexus-app-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nexus app starter — runnable record-system skeleton: shell + vendored nexus-ui (shadcn/ui on the Nexus token canvas) + config-driven record-core + mock backend + data-spine module + journeys harness + docs contracts.",
  "scripts": {
    "dev": "node server/server.mjs & vite",
    "build": "tsc -b && vite build",
    "serve": "node server/server.mjs",
    "journeys": "node journeys/run.mjs",
    "test": "node --test journeys/unit/*.test.ts",
    "sync-ui": "node scripts/sync-ui.mjs",
    "precheck": "node scripts/precheck.mjs",
    "model": "node scripts/gen-model.mjs",
    "generate": "node scripts/generate.mjs",
    "mcp": "node scripts/mcp-server.mjs"
  },
